generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductStatus {
  PENDING
  TRAINED
}

enum ChannelType {
  FACEBOOK
  INSTAGRAM
  WHATSAPP
  WIDGET
}

enum ConversationStatus {
  AI_MANAGED
  ACTIVE
  CLOSED
}

enum Sender {
  CUSTOMER
  AI
  MERCHANT
}

enum OrderStatus {
  PENDING
  FULFILLED
  CANCELLED
}

model Merchant {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatarUrl    String?
  store        Store?
  createdAt    DateTime @default(now())
}

model Store {
  id            String         @id @default(cuid())
  merchant      Merchant       @relation(fields: [merchantId], references: [id])
  merchantId    String         @unique
  name          String
  tone          String         @default("Direct, helpful, and highly sophisticated.")
  style         String         @default("narrative")
  customInstructions String    @default("")
  widgetKey     String         @unique @default(cuid())
  products      Product[]
  channels      Channel[]
  conversations Conversation[]
  orders        Order[]
  createdAt     DateTime       @default(now())
}

model Product {
  id          String        @id @default(cuid())
  store       Store         @relation(fields: [storeId], references: [id])
  storeId     String
  name        String
  sku         String
  price       Decimal
  inventory   Int
  description String?
  imageUrl    String?
  status      ProductStatus @default(PENDING)
  createdAt   DateTime      @default(now())

  @@unique([storeId, sku])
}

model Channel {
  id          String      @id @default(cuid())
  store       Store       @relation(fields: [storeId], references: [id])
  storeId     String
  type        ChannelType
  connected   Boolean     @default(false)
  credentials Json?
  externalId  String?

  @@unique([storeId, type])
}

model Conversation {
  id             String             @id @default(cuid())
  store          Store              @relation(fields: [storeId], references: [id])
  storeId        String
  channelType    ChannelType
  externalUserId String?
  customerName   String?
  status         ConversationStatus @default(AI_MANAGED)
  isComplaint    Boolean            @default(false)
  cart           Json?
  messages       Message[]
  lastMessageAt  DateTime           @default(now())
  createdAt      DateTime           @default(now())
}

model Message {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
  sender         Sender
  text           String
  // True for an AI-drafted reply awaiting merchant approval (Copilot off / manual mode) —
  // not yet delivered to the real customer. False for anything already sent/delivered.
  pending        Boolean      @default(false)
  // Meta's message id, when this row originated from a webhook event. Used to make webhook
  // processing idempotent, since Meta's delivery is "at-least-once" and may redeliver.
  externalId     String?      @unique
  meta           Json?
  createdAt      DateTime     @default(now())
}

model Order {
  id             String      @id @default(cuid())
  store          Store       @relation(fields: [storeId], references: [id])
  storeId        String
  conversationId String?
  items          Json
  customerName   String
  address        String
  status         OrderStatus @default(PENDING)
  total          Decimal
  createdAt      DateTime    @default(now())
}
